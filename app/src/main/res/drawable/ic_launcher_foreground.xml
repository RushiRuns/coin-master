                android:endX="84"
                android:endY="84"
                android:type="linear">
                <item android:color="#FFE082" android:offset="0.0" /> <!-- Light Gold -->
                <item android:color="#FFB300" android:offset="0.5" /> <!-- Medium Gold -->
                <item android:color="#FF6F00" android:offset="1.0" /> <!-- Dark Bronze/Amber -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Rim Ring (Subtle shadow ring to give depth) -->
