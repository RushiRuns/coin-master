        android:pathData="M54,54m-25,0a25,25 0,1 1,50 0a25,25 0,1 1,-50 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="29"
                android:startY="29"
                android:endX="79"
                android:endY="79"
                android:type="linear">
                <item android:color="#FFD54F" android:offset="0.0" /> <!-- Gold 300 -->
                <item android:color="#FFC107" android:offset="1.0" /> <!-- Gold 500 -->
            </gradient>
        </aapt:attr>
    </path>

