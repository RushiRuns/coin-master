<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/onboardingFragment">

    <fragment
        android:id="@+id/onboardingFragment"
        android:name="com.rushi.coinmaster.ui.onboarding.OnboardingFragment"
        android:label="OnboardingFragment"
        tools:layout="@layout/fragment_onboarding">
        <action
            android:id="@+id/action_onboardingFragment_to_accountsFragment"
            app:destination="@id/accountsFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/placeholderFragment"
        android:name="com.rushi.coinmaster.ui.PlaceholderFragment"
        android:label="PlaceholderFragment"
        tools:layout="@layout/fragment_placeholder">
        <action
            android:id="@+id/action_placeholderFragment_to_accountsFragment"
            app:destination="@id/accountsFragment" />
    </fragment>

    <fragment
        android:id="@+id/accountsFragment"
        android:name="com.rushi.coinmaster.ui.accounts.AccountsFragment"
        android:label="AccountsFragment"
        tools:layout="@layout/fragment_accounts">
        <action
            android:id="@+id/action_accountsFragment_to_addEditAccountFragment"
            app:destination="@id/addEditAccountFragment" />
        <action
            android:id="@+id/action_accountsFragment_to_addTransactionFragment"
            app:destination="@id/addTransactionFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditAccountFragment"
        android:name="com.rushi.coinmaster.ui.accounts.AddEditAccountFragment"
        android:label="AddEditAccountFragment"
        tools:layout="@layout/fragment_add_edit_account">
        <argument
            android:name="accountId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

    <fragment
        android:id="@+id/budgetFragment"
        android:name="com.rushi.coinmaster.ui.budget.BudgetFragment"
        android:label="BudgetFragment"
        tools:layout="@layout/fragment_budget">
        <action
            android:id="@+id/action_budgetFragment_to_addEditEnvelopeFragment"
            app:destination="@id/addEditEnvelopeFragment" />
        <action
            android:id="@+id/action_budgetFragment_to_monthSetupFragment"
            app:destination="@id/monthSetupFragment" />
        <action
            android:id="@+id/action_budgetFragment_to_addTransactionFragment"
            app:destination="@id/addTransactionFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditEnvelopeFragment"
        android:name="com.rushi.coinmaster.ui.budget.AddEditEnvelopeFragment"
        android:label="AddEditEnvelopeFragment"
        tools:layout="@layout/fragment_add_edit_envelope">
        <argument
            android:name="categoryId"
            app:argType="long"
            android:defaultValue="0L" />
        <argument
            android:name="bucketTypeOrdinal"
            app:argType="integer"
            android:defaultValue="-1" />
    </fragment>

    <fragment
        android:id="@+id/monthSetupFragment"
        android:name="com.rushi.coinmaster.ui.budget.MonthSetupFragment"
        android:label="MonthSetupFragment"
        tools:layout="@layout/fragment_month_setup">
        <argument
            android:name="budgetMonthId"
            app:argType="integer"
            android:defaultValue="0" />
    </fragment>

    <fragment
        android:id="@+id/addTransactionFragment"
        android:name="com.rushi.coinmaster.ui.transactions.AddTransactionFragment"
        android:label="AddTransactionFragment"
        tools:layout="@layout/fragment_add_transaction" />

</navigation>
