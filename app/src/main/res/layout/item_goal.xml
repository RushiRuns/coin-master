<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Goal Name (Subtitle 1) -->
            <TextView
                android:id="@+id/tv_goal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MacBook Pro"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Goal Category (Caption) -->
            <TextView
                android:id="@+id/tv_goal_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_goal_name"
                android:layout_marginTop="2dp"
                android:text="Envelope: Tech Savings"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ImageButton
                android:id="@+id/btn_delete_goal"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="-8dp"
                android:layout_marginBottom="-8dp"
                android:layout_marginEnd="-8dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                android:contentDescription="@string/cd_delete_goal"
                app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btn_edit_goal"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginTop="-8dp"
                android:layout_marginBottom="-8dp"
                android:layout_toStartOf="@id/btn_delete_goal"
                android:layout_alignParentTop="true"
                android:padding="12dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_edit"
                android:contentDescription="@string/cd_edit_goal"
                app:tint="@color/text_secondary" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tv_goal_saved"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹20,000 saved"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_goal_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="of ₹60,000"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </RelativeLayout>

        <!-- Linear Progress Indicator (MD2: 4dp thick, square ends) -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:trackThickness="4dp"
            app:trackCornerRadius="0dp"
            app:indicatorColor="@color/primary"
            app:trackColor="@color/divider" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_goal_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target: Dec 2026"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_goal_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="33%"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Divider line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@color/divider" />

        <!-- Monthly Savings Needed (Body 2) -->
        <TextView
            android:id="@+id/tv_monthly_savings_needed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monthly savings needed: ₹8,000/month"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
