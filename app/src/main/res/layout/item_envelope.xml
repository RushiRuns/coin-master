<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Category Color indicator badge -->
    <View
        android:id="@+id/view_envelope_color"
        android:layout_width="8dp"
        android:layout_height="24dp"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Category Icon -->
    <ImageView
        android:id="@+id/iv_envelope_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="12dp"
        android:src="@android:drawable/ic_menu_help"
        app:tint="@color/text_secondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/view_envelope_color" />

    <!-- Category Name -->
    <TextView
        android:id="@+id/tv_envelope_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Groceries"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_envelope_icon"
        app:layout_constraintEnd_toStartOf="@id/layout_allocation_click" />

    <!-- Spent breakdown indicator -->
    <TextView
        android:id="@+id/tv_envelope_spent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="2dp"
        android:text="Spent: ₹0.00"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tv_envelope_name"
        app:layout_constraintStart_toEndOf="@id/iv_envelope_icon"
        app:layout_constraintEnd_toStartOf="@id/layout_allocation_click" />

    <!-- Clickable Allocation Input Box -->
    <LinearLayout
        android:id="@+id/layout_allocation_click"
        android:layout_width="100dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_allocation_box"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btn_edit_envelope">

        <TextView
            android:id="@+id/tv_allocated_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0.00"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Category Metadata Edit Button -->
    <ImageButton
        android:id="@+id/btn_edit_envelope"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_edit"
        android:contentDescription="Edit Envelope"
        app:tint="@color/text_secondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
